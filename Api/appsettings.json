 {
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "LaboratoryRasf": "",
    "RasfPorta": ""
  },
  "Jwt": {
    "Issuer": "BonyadRazi.Auth",
    "Audience": "BonyadRazi.Portal",
