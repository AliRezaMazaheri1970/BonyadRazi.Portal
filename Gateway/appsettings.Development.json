{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",

  "Security": {
    "ValidateJwtAtGateway": true
  },

  "Jwt": {
    "Issuer": "BonyadRazi.Auth",
    "Audience": "BonyadRazi.Portal"
  },

  "ReverseProxy": {
    "Routes": {
      "api-route": {
        "ClusterId": "auth-cluster",
        "Match": {
          "Path": "/api/{**catch-all}"
        }
      },
      "webapp-route": {
        "ClusterId": "webapp-cluster",
        "Match": {
          "Path": "/{**catch-all}"
        }
      }
    },

    "Clusters": {
      "auth-cluster": {
        "Destinations": {
          "auth": { "Address": "http://localhost:5056/" }
        }
      },
      "webapp-cluster": {
        "Destinations": {
          "web": { "Address": "http://localhost:5080/" }
        }
      }
    }
  }
}