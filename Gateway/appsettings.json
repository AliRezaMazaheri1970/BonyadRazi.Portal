{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",

  "Jwt": {
    "Issuer": "BonyadRazi.Auth",
    "Audience": "BonyadRazi.Portal"
  },

  "Security": {
    "ValidateJwtAtGateway": true,
    "AllowLoopbackInDevelopment": false,
    "BypassIpAllowlistInTesting": false,
    "AllowedCidrs": [
      "192.168.0.0/25",
      "192.168.93.0/27",
      "192.168.94.0/26",
      "192.168.95.0/27",
      "192.168.96.0/27",
      "192.168.97.0/27",
      "192.168.98.0/27",
      "192.168.99.0/27",
      "192.168.100.0/27",
      "192.168.101.0/27",
      "192.168.102.0/27",
      "192.168.103.0/24",
      "192.168.104.0/27",
      "192.168.105.0/27"
    ],
    "ApiAllowPrefixes": [
      "/api/auth",
      "/api/users",
      "/api/companies",
      "/api/audit",
      "/health",
      "/gateway/health"
    ]
  },

  "ReverseProxy": {
    "Routes": {
      "auth-login": {
        "ClusterId": "auth-cluster",
        "Match": {
          "Path": "/api/auth/login"
        }
      },

      "auth-refresh": {
        "ClusterId": "auth-cluster",
        "Match": {
          "Path": "/api/auth/refresh"
        }
      },

      "auth-revoke": {
        "ClusterId": "auth-cluster",
        "Match": {
          "Path": "/api/auth/revoke"
        }
      },

      "auth-protected": {
        "ClusterId": "auth-cluster",
        "Match": {
          "Path": "/api/auth/{**catch-all}"
        }
      },

      "users": {
        "ClusterId": "auth-cluster",
        "Match": {
          "Path": "/api/users/{**catch-all}"
        }
      },

      "companies": {
        "ClusterId": "auth-cluster",
        "Match": {
          "Path": "/api/companies/{**catch-all}"
        }
      },

      "audit": {
        "ClusterId": "auth-cluster",
        "Match": {
          "Path": "/api/audit/{**catch-all}"
        }
      },

      "service-health": {
        "ClusterId": "auth-cluster",
        "Match": {
          "Path": "/health"
        }
      },

      "webapp": {
        "ClusterId": "webapp-cluster",
        "Match": {
          "Path": "/{**catch-all}"
        }
      }
    },

    "Clusters": {
      "auth-cluster": {
        "Destinations": {
          "auth": {
            "Address": "http://192.168.93.27:5056/"
          }
        }
      },

      "webapp-cluster": {
        "Destinations": {
          "web": {
            "Address": "http://192.168.93.27:5080/"
          }
        }
      }
    }
  }
}